<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Trouver un restaurant — MenuCam</title>
  <meta name="description" content="Parcourez les restaurants disponibles sur MenuCam et commandez en ligne."/>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🍽️</text></svg>"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
  <link rel="stylesheet" href="/css/app.css"/>
  <style>
    body { background:#F3F4F6; }
    .pub-hero { background:linear-gradient(135deg,#111827 0%,#1e293b 60%,#0f172a 100%); padding:3rem 1.5rem 4rem; position:relative; overflow:hidden; }
    .pub-hero::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 30% 50%,rgba(245,158,11,.18) 0,transparent 60%); }
    .pub-hero-inner { max-width:700px; margin:0 auto; position:relative; z-index:1; text-align:center; }
    .pub-hero h1 { font-family:'Bricolage Grotesque',sans-serif; font-size:2.4rem; font-weight:800; color:#fff; margin-bottom:.5rem; }
    .pub-hero p { color:rgba(255,255,255,.6); font-size:1rem; margin-bottom:2rem; }
    .pub-search-form { display:flex; gap:10px; }
    .pub-search-form input, .pub-search-form select { flex:1; padding:12px 16px; border:none; border-radius:10px; font-size:14px; font-family:inherit; outline:none; }
    .pub-search-form button { padding:12px 24px; background:#F59E0B; color:#111; border:none; border-radius:10px; font-weight:700; cursor:pointer; white-space:nowrap; font-family:inherit; font-size:14px; }
    .pub-search-form button:hover { background:#D97706; }
    .pub-body { max-width:1100px; margin:0 auto; padding:2rem 1.5rem; }
    .resto-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1.25rem; }
    .resto-card { background:#fff; border-radius:16px; overflow:hidden; border:1px solid #E5E7EB; box-shadow:0 1px 3px rgba(0,0,0,.06); transition:transform .2s,box-shadow .2s; cursor:pointer; }
    .resto-card:hover { transform:translateY(-3px); box-shadow:0 8px 20px rgba(0,0,0,.1); }
    .resto-card-img { height:150px; background:linear-gradient(135deg,#1e293b,#374151); display:flex; align-items:center; justify-content:center; font-size:3rem; position:relative; overflow:hidden; }
    .resto-card-img img { width:100%; height:100%; object-fit:cover; }
    .resto-card-body { padding:1.25rem; }
    .resto-card-name { font-family:'Bricolage Grotesque',sans-serif; font-weight:800; font-size:1.1rem; margin-bottom:4px; }
    .resto-card-meta { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:.75rem; }
    .meta-pill { display:inline-flex; align-items:center; gap:4px; font-size:12px; color:#6B7280; background:#F3F4F6; padding:3px 8px; border-radius:999px; }
    .statut-chip { display:inline-flex; align-items:center; gap:5px; font-size:12px; font-weight:600; padding:4px 10px; border-radius:999px; }
    .statut-ouvert { background:#D1FAE5; color:#059669; }
    .statut-ferme { background:#FEE2E2; color:#B91C1C; }
    .statut-warn { background:#FEF3C7; color:#92400E; }
    .resto-card-btn { display:flex; align-items:center; justify-content:center; gap:6px; width:100%; padding:10px; background:#F59E0B; color:#111; border:none; border-radius:8px; font-weight:700; font-size:13px; cursor:pointer; font-family:inherit; margin-top:10px; }
    .resto-card-btn:hover { background:#D97706; }
    .pub-empty { text-align:center; padding:4rem 2rem; }
    .pub-empty-icon { font-size:4rem; margin-bottom:1rem; }
    .results-bar { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.25rem; }
    .results-count { font-size:14px; color:#6B7280; }
    @media(max-width:600px){ .pub-search-form{flex-direction:column} .pub-hero h1{font-size:1.7rem} }
  </style>
</head>
<body>

<div class="pub-hero">
  <div class="pub-hero-inner">
    <div style="font-size:2.5rem;margin-bottom:.5rem">🍽️</div>
    <h1>Trouvez votre restaurant</h1>
    <p>Parcourez les menus, commandez en ligne depuis chez vous</p>
    <form method="GET" action="/restaurants" class="pub-search-form">
      <input type="text" name="q" value="<%= q %>" placeholder="Nom du restaurant, cuisine…"/>
      <select name="ville" style="flex:0 0 140px">
        <option value="">Toutes les villes</option>
        <% villes.forEach(v => { %><option value="<%= v %>" <%= ville===v?'selected':'' %>><%= v %></option><% }); %>
      </select>
      <button type="submit"><i class="bi bi-search"></i> Rechercher</button>
    </form>
  </div>
</div>

<div class="pub-body">
  <div class="results-bar">
    <div class="results-count">
      <% if(q || ville) { %>
        <strong><%= restaurants.length %></strong> résultat(s) pour « <%= q || ville %> »
        — <a href="/restaurants" style="color:var(--brand)">Réinitialiser</a>
      <% } else { %>
        <strong><%= restaurants.length %></strong> restaurant(s) disponible(s)
      <% } %>
    </div>
    <a href="/" style="font-size:13px;color:#6B7280"><i class="bi bi-arrow-left"></i> Retour</a>
  </div>

  <% if(restaurants.length === 0) { %>
    <div class="pub-empty">
      <div class="pub-empty-icon">🔍</div>
      <h3 style="font-family:'Bricolage Grotesque',sans-serif;margin-bottom:.5rem">Aucun restaurant trouvé</h3>
      <p style="color:#6B7280">Essayez un autre terme ou effacez les filtres.</p>
      <a href="/restaurants" class="btn btn-primary" style="margin-top:1rem;display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:#F59E0B;color:#111;border-radius:10px;font-weight:700">Voir tous les restaurants</a>
    </div>
  <% } else { %>
    <div class="resto-grid">
      <% restaurants.forEach(r => {
        const s = r.statut_ouverture;
        const chipClass = s.ouvert ? 'statut-ouvert' : (s.statut === 'ferme_bientot' ? 'statut-warn' : 'statut-ferme');
      %>
      <div class="resto-card" onclick="window.location='/restaurants/<%= r.slug || r._id %>'">
        <div class="resto-card-img">
          <% if(r.logo) { %><img src="<%= r.logo %>" alt="<%= r.nom %>"/><% } else { %>🍽️<% } %>
          <div style="position:absolute;top:10px;right:10px">
            <span class="statut-chip <%= chipClass %>"><%= s.message %></span>
          </div>
        </div>
        <div class="resto-card-body">
          <div class="resto-card-name"><%= r.nom %></div>
          <div class="resto-card-meta">
            <% if(r.ville) { %><span class="meta-pill"><i class="bi bi-geo-alt"></i> <%= r.ville %></span><% } %>
            <% if(r.telephone) { %><span class="meta-pill"><i class="bi bi-telephone"></i> <%= r.telephone %></span><% } %>
            <% if(r.note_moyenne) { %><span class="meta-pill"><i class="bi bi-star-fill" style="color:#F59E0B"></i> <%= r.note_moyenne %></span><% } %>
          </div>
          <% if(r.description) { %><p style="font-size:13px;color:#6B7280;margin-bottom:.75rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden"><%= r.description %></p><% } %>
          <button class="resto-card-btn"><i class="bi bi-menu-button-wide"></i> Voir le menu</button>
        </div>
      </div>
      <% }); %>
    </div>
  <% } %>
</div>

<footer style="text-align:center;padding:2rem;font-size:13px;color:#9CA3AF;border-top:1px solid #E5E7EB;margin-top:2rem">
  <a href="/" style="font-weight:700;color:#F59E0B">🍽️ MenuCam</a> — Plateforme de menu digital pour restaurants
</footer>
</body></html>
