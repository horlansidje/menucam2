<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>MenuCam — Digitalisez votre restaurant</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🍽️</text></svg>"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Bricolage+Grotesque:wght@400;600;700;800&display=swap');
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Plus Jakarta Sans',sans-serif;background:#0a0a0f;color:#fff;-webkit-font-smoothing:antialiased}
    a{text-decoration:none;color:inherit}
    nav{position:sticky;top:0;z-index:100;background:rgba(10,10,15,0.9);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.06);padding:1rem 2rem;display:flex;align-items:center;justify-content:space-between}
    .nav-brand{display:flex;align-items:center;gap:10px}
    .nav-logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#F59E0B,#D97706);display:flex;align-items:center;justify-content:center;font-size:1.1rem}
    .nav-name{font-family:'Bricolage Grotesque',sans-serif;font-size:1.3rem;font-weight:800;color:#fff}
    .nav-links{display:flex;align-items:center;gap:10px}
    .btn-nav-outline{padding:8px 18px;border-radius:8px;border:1.5px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);font-size:14px;font-weight:500;transition:all .2s}
    .btn-nav-outline:hover{border-color:rgba(255,255,255,0.4);color:#fff}
    .btn-nav-primary{padding:8px 18px;border-radius:8px;background:#F59E0B;color:#111;font-size:14px;font-weight:700;transition:all .2s;box-shadow:0 4px 14px rgba(245,158,11,.35)}
    .btn-nav-primary:hover{background:#D97706;transform:translateY(-1px)}
    /* Hero */
    .hero{min-height:calc(100vh - 68px);display:flex;align-items:center;position:relative;overflow:hidden;padding:4rem 2rem}
    .hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 20% 50%,rgba(245,158,11,.12) 0,transparent 50%),radial-gradient(ellipse at 80% 20%,rgba(16,185,129,.08) 0,transparent 45%),radial-gradient(ellipse at 50% 100%,rgba(139,92,246,.08) 0,transparent 50%)}
    .hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.02) 1px,transparent 1px);background-size:60px 60px}
    .hero-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;position:relative;z-index:1;width:100%}
    .hero-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.25);color:#F59E0B;padding:6px 14px;border-radius:999px;font-size:13px;font-weight:600;margin-bottom:1.5rem}
    .hero-title{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(2.2rem,4.5vw,3.5rem);line-height:1.1;letter-spacing:-.03em;margin-bottom:1.25rem}
    .hero-title .g{background:linear-gradient(135deg,#F59E0B,#FCD34D);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
    .hero-desc{font-size:1.05rem;color:rgba(255,255,255,.55);line-height:1.8;margin-bottom:2rem;max-width:520px}
    .hero-cta{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:2.5rem}
    .btn-hero-primary{padding:14px 28px;border-radius:12px;background:#F59E0B;color:#111;font-weight:700;font-size:1rem;display:inline-flex;align-items:center;gap:8px;transition:all .2s;box-shadow:0 6px 24px rgba(245,158,11,.4)}
    .btn-hero-primary:hover{background:#D97706;transform:translateY(-2px);box-shadow:0 10px 32px rgba(245,158,11,.5)}
    .btn-hero-ghost{padding:14px 28px;border-radius:12px;border:1.5px solid rgba(255,255,255,.12);color:rgba(255,255,255,.7);font-weight:600;font-size:1rem;transition:all .2s}
    .btn-hero-ghost:hover{border-color:rgba(255,255,255,.3);color:#fff}
    .hero-trust{display:flex;flex-wrap:wrap;gap:16px;font-size:13px;color:rgba(255,255,255,.35)}
    .hero-trust span{display:flex;align-items:center;gap:5px}
    /* Phone */
    .phone-wrap{display:flex;justify-content:center;align-items:center}
    .phone{width:280px;background:#1a1a2e;border:2px solid rgba(255,255,255,.08);border-radius:36px;padding:1.5rem 1.25rem;box-shadow:0 40px 80px rgba(0,0,0,.6),0 0 0 1px rgba(255,255,255,.04);position:relative}
    .phone-notch{width:80px;height:5px;background:rgba(255,255,255,.08);border-radius:3px;margin:0 auto 1.25rem}
    .p-header{display:flex;align-items:center;gap:10px;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid rgba(255,255,255,.06)}
    .p-avatar{width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,#F59E0B,#D97706);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
    .p-name{font-family:'Bricolage Grotesque',sans-serif;font-weight:700;color:#fff;font-size:14px}
    .p-rating{font-size:11px;color:#F59E0B}
    .p-cat{font-size:10px;font-weight:700;color:#F59E0B;text-transform:uppercase;letter-spacing:.1em;padding:6px 0 3px}
    .p-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04)}
    .p-item-name{font-size:13px;color:#d0c8b8}
    .p-item-price{font-size:12px;color:#8a7a6a}
    .p-add{width:28px;height:28px;border-radius:8px;background:rgba(245,158,11,.15);border:1px solid rgba(245,158,11,.35);color:#F59E0B;display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer}
    .p-add.a{background:#F59E0B;color:#111;border:none}
    .p-cart{background:#F59E0B;border-radius:10px;padding:10px 12px;display:flex;justify-content:space-between;align-items:center;margin-top:10px}
    .p-cart span{color:#111;font-size:12px;font-weight:600}
    .p-cart button{background:rgba(0,0,0,.15);color:#111;border:none;border-radius:6px;padding:4px 8px;font-size:10px;font-weight:700;cursor:pointer}
    /* Features */
    .features{background:#0d0d14;padding:6rem 2rem;border-top:1px solid rgba(255,255,255,.05)}
    .section-header{text-align:center;max-width:600px;margin:0 auto 3.5rem}
    .section-tag{display:inline-block;background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.2);color:#F59E0B;padding:5px 14px;border-radius:999px;font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin-bottom:1rem}
    .section-title{font-family:'Bricolage Grotesque',sans-serif;font-size:2.2rem;font-weight:800;color:#fff;margin-bottom:.75rem;letter-spacing:-.02em}
    .section-desc{font-size:1rem;color:rgba(255,255,255,.45);line-height:1.7}
    .feat-grid{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem}
    .feat-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:1.5rem;transition:all .3s}
    .feat-card:hover{background:rgba(255,255,255,.05);border-color:rgba(245,158,11,.2);transform:translateY(-3px)}
    .feat-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:1rem}
    .feat-card h3{font-family:'Bricolage Grotesque',sans-serif;font-size:1.05rem;font-weight:700;color:#fff;margin-bottom:.5rem}
    .feat-card p{font-size:13px;color:rgba(255,255,255,.45);line-height:1.7}
    /* Pricing */
    .pricing{padding:6rem 2rem;background:#080810;border-top:1px solid rgba(255,255,255,.05)}
    .plans-grid{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem}
    .plan{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:2rem;position:relative}
    .plan.popular{border-color:#F59E0B;background:rgba(245,158,11,.05);box-shadow:0 8px 40px rgba(245,158,11,.15)}
    .popular-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#F59E0B;color:#111;font-size:11px;font-weight:800;padding:4px 14px;border-radius:999px;white-space:nowrap;letter-spacing:.03em}
    .plan-name{font-family:'Bricolage Grotesque',sans-serif;font-size:1.1rem;font-weight:700;color:rgba(255,255,255,.7);margin-bottom:.75rem}
    .plan-price{font-family:'Bricolage Grotesque',sans-serif;font-size:2.2rem;font-weight:800;color:#F59E0B;margin-bottom:1.5rem}
    .plan-price span{font-size:14px;color:rgba(255,255,255,.35);font-weight:400}
    .plan-feats{list-style:none;margin-bottom:2rem}
    .plan-feats li{font-size:14px;color:rgba(255,255,255,.5);padding:7px 0;border-bottom:1px solid rgba(255,255,255,.05);display:flex;align-items:center;gap:8px}
    .plan-feats li:last-child{border:none}
    .btn-plan{display:block;text-align:center;padding:12px;border-radius:10px;font-weight:700;font-size:14px;transition:all .2s}
    .btn-plan-outline{border:1.5px solid rgba(255,255,255,.12);color:rgba(255,255,255,.6)}
    .btn-plan-outline:hover{border-color:#F59E0B;color:#F59E0B}
    .btn-plan-primary{background:#F59E0B;color:#111;box-shadow:0 4px 16px rgba(245,158,11,.3)}
    .btn-plan-primary:hover{background:#D97706}
    /* Footer */
    footer{background:#050508;padding:3rem 2rem;text-align:center;border-top:1px solid rgba(255,255,255,.05)}
    footer p{color:rgba(255,255,255,.25);font-size:13px;margin-top:.5rem}
    @media(max-width:768px){.hero-inner{grid-template-columns:1fr;text-align:center}.phone-wrap{display:none}.hero-cta{justify-content:center}.hero-trust{justify-content:center}.nav-links .btn-nav-outline{display:none}}
  </style>
</head>
<body>

<nav>
  <div class="nav-brand"><div class="nav-logo">🍽️</div><div class="nav-name">MenuCam</div></div>
  <div class="nav-links">
    <a href="/auth/connexion" class="btn-nav-outline">Connexion</a>
    <a href="/auth/inscription" class="btn-nav-primary">Démarrer gratuitement</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-bg"></div><div class="hero-grid"></div>
  <div class="hero-inner">
    <div>
      <div class="hero-tag">🇨🇲 Conçu pour le Cameroun</div>
      <h1 class="hero-title">La plateforme SaaS pour <span class="g">digitaliser votre restaurant</span></h1>
      <p class="hero-desc">Menu QR Code, commandes WhatsApp, livraison, paiement Mobile Money, analytics et bien plus — tout en une seule plateforme moderne.</p>
      <div class="hero-cta">
        <a href="/auth/inscription" class="btn-hero-primary"><i class="bi bi-rocket-takeoff"></i> Créer mon restaurant gratuitement</a>
        <a href="#features" class="btn-hero-ghost">Voir les fonctionnalités →</a>
      </div>
      <div class="hero-trust">
        <span>✅ QR Code unique</span>
        <span>✅ MTN &amp; Orange Money</span>
        <span>✅ Livraison intégrée</span>
        <span>✅ Temps réel</span>
        <span>✅ Reçus PDF</span>
      </div>
    </div>
    <div class="phone-wrap">
      <div class="phone">
        <div class="phone-notch"></div>
        <div class="p-header"><div class="p-avatar">🍽️</div><div><div class="p-name">Chez Maman Biya</div><div class="p-rating">⭐ 4.8 · Akwa, Douala</div></div></div>
        <div class="p-cat">🥘 Plats principaux</div>
        <div class="p-item"><div><div class="p-item-name">Ndolé spécial</div><div class="p-item-price">4 500 FCFA</div></div><div class="p-add">+</div></div>
        <div class="p-item"><div><div class="p-item-name">Poulet DG</div><div class="p-item-price">5 500 FCFA</div></div><div class="p-add">+</div></div>
        <div class="p-cat">🥤 Jus naturels</div>
        <div class="p-item"><div><div class="p-item-name">Jus de bissap</div><div class="p-item-price">500 FCFA</div></div><div class="p-add a">1</div></div>
        <div class="p-cart"><span>1 article — 500 FCFA</span><button>Commander 🛵</button></div>
      </div>
    </div>
  </div>
</section>

<section class="features" id="features">
  <div class="section-header">
    <div class="section-tag">Fonctionnalités</div>
    <h2 class="section-title">Tout ce dont votre restaurant a besoin</h2>
    <p class="section-desc">Une plateforme complète pour digitaliser, gérer et développer votre restaurant.</p>
  </div>
  <div class="feat-grid">
    <div class="feat-card"><div class="feat-icon" style="background:rgba(245,158,11,.1)">📱</div><h3>Menu QR Code</h3><p>QR code unique par restaurant. Vos clients scannent et voient le menu mis à jour en temps réel.</p></div>
    <div class="feat-card"><div class="feat-icon" style="background:rgba(16,185,129,.1)">🛵</div><h3>Livraison intégrée</h3><p>Gérez vos livreurs, assignez des commandes et suivez les livraisons en temps réel.</p></div>
    <div class="feat-card"><div class="feat-icon" style="background:rgba(59,130,246,.1)">💳</div><h3>Mobile Money</h3><p>Paiement MTN et Orange Money intégré directement depuis la page menu.</p></div>
    <div class="feat-card"><div class="feat-icon" style="background:rgba(139,92,246,.1)">📄</div><h3>Reçus PDF</h3><p>Génération automatique de reçus PDF professionnels avec QR code de suivi.</p></div>
    <div class="feat-card"><div class="feat-icon" style="background:rgba(245,158,11,.1)">📦</div><h3>Suivi commandes</h3><p>Système de suivi en temps réel avec lien unique par commande. Expire après livraison.</p></div>
    <div class="feat-card"><div class="feat-icon" style="background:rgba(239,68,68,.1)">📊</div><h3>Analytics avancés</h3><p>Graphiques CA, plats populaires, heures de pointe. Prenez de meilleures décisions.</p></div>
    <div class="feat-card"><div class="feat-icon" style="background:rgba(16,185,129,.1)">⭐</div><h3>Avis clients</h3><p>Notation 5 étoiles après commande. Répondez aux avis et améliorez votre service.</p></div>
    <div class="feat-card"><div class="feat-icon" style="background:rgba(245,158,11,.1)">🎁</div><h3>Codes promo</h3><p>Créez des promotions en pourcentage ou montant fixe avec limite d'usage et date d'expiration.</p></div>
  </div>
</section>

<section class="pricing">
  <div class="section-header">
    <div class="section-tag">Tarifs</div>
    <h2 class="section-title">Simple et transparent</h2>
    <p class="section-desc">Sans engagement, sans frais cachés.</p>
  </div>
  <div class="plans-grid">
    <div class="plan"><div class="plan-name">Gratuit</div><div class="plan-price">0 <span>FCFA/mois</span></div><ul class="plan-feats"><li>✅ Jusqu'à 20 plats</li><li>✅ QR code unique</li><li>✅ Commandes WhatsApp</li><li style="opacity:.4">❌ Analytics avancés</li><li style="opacity:.4">❌ Reçus PDF</li></ul><a href="/auth/inscription" class="btn-plan btn-plan-outline">Commencer</a></div>
    <div class="plan popular"><div class="popular-badge">⭐ Le plus populaire</div><div class="plan-name">Pro</div><div class="plan-price">15 000 <span>FCFA/mois</span></div><ul class="plan-feats"><li>✅ Plats illimités</li><li>✅ Livraison &amp; livreurs</li><li>✅ Mobile Money</li><li>✅ Reçus PDF</li><li>✅ Analytics complets</li></ul><a href="/auth/inscription" class="btn-plan btn-plan-primary">Essai 30 jours gratuit</a></div>
    <div class="plan"><div class="plan-name">Business</div><div class="plan-price">25 000 <span>FCFA/mois</span></div><ul class="plan-feats"><li>✅ Tout du plan Pro</li><li>✅ Multi-restaurants</li><li>✅ Support prioritaire</li><li>✅ API personnalisée</li><li>✅ Rapports personnalisés</li></ul><a href="/auth/inscription" class="btn-plan btn-plan-outline">Contacter</a></div>
  </div>
</section>

<footer>
  <div class="nav-brand" style="justify-content:center;margin-bottom:.75rem"><div class="nav-logo">🍽️</div><div class="nav-name">MenuCam</div></div>
  <p>Fait avec ❤️ à Douala, Cameroun · 2024</p>
  <p>Pour les restaurants de Douala, Yaoundé et partout au Cameroun</p>
</footer>

</body></html>
