<%- include('../partials/head', {title:'Commandes'}) %>
<%- include('../partials/sidebar', {activePage:'commandes', enAttenteCount: stats.enAttente}) %>
<div class="main-content">
  <div class="topbar">
    <div class="topbar-left"><button class="sidebar-toggle" id="sidebarToggle"><i class="bi bi-list"></i></button><div class="topbar-title">Commandes</div></div>
    <div class="topbar-right"><div class="live-chip"><span class="status-dot"></span> Temps réel</div></div>
  </div>
  <div class="page-body">
    <% if(success&&success.length>0){%><div class="alert alert-success"><i class="bi bi-check-circle"></i><%=success%></div><%}%>
    <div class="stats-row">
      <div class="stat-card stat-brand"><div class="stat-card-icon" style="background:#FEF3C7;color:#D97706"><i class="bi bi-clock" style="font-size:1.3rem"></i></div><div class="stat-card-value"><%=stats.enAttente%></div><div class="stat-card-label">En attente</div></div>
      <div class="stat-card stat-blue"><div class="stat-card-icon" style="background:#DBEAFE;color:#2563EB"><i class="bi bi-fire" style="font-size:1.3rem"></i></div><div class="stat-card-value"><%=stats.enPreparation%></div><div class="stat-card-label">En préparation</div></div>
      <div class="stat-card stat-purple"><div class="stat-card-icon" style="background:#EDE9FE;color:#7C3AED"><i class="bi bi-scooter" style="font-size:1.3rem"></i></div><div class="stat-card-value"><%=stats.enLivraison%></div><div class="stat-card-label">En livraison</div></div>
      <div class="stat-card stat-green"><div class="stat-card-icon" style="background:#D1FAE5;color:#059669"><i class="bi bi-check-circle" style="font-size:1.3rem"></i></div><div class="stat-card-value"><%=stats.servies%></div><div class="stat-card-label">Servies/Livrées</div></div>
      <div class="stat-card stat-brand"><div class="stat-card-icon" style="background:#FEF3C7;color:#D97706"><i class="bi bi-wallet2" style="font-size:1.3rem"></i></div><div class="stat-card-value"><%=stats.caToday.toLocaleString('fr-FR')%></div><div class="stat-card-label">FCFA aujourd'hui</div></div>
    </div>

    <div class="card" style="margin-bottom:1.5rem">
      <div class="card-body" style="padding:.75rem 1.25rem">
        <form method="GET" action="/commandes" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
          <select name="statut" class="form-control form-select" style="width:180px" onchange="this.form.submit()">
            <option value="toutes" <%= filtreStatut==='toutes' ? 'selected' : '' %>Toutes les commandes</option>
            <option value="en_attente" <%= filtreStatut==='en_attente' ? 'selected' : '' %>⏳ En attente</option>
            <option value="en_preparation" <%= filtreStatut==='en_preparation' ? 'selected' : '' %>👨‍🍳 En préparation</option>
            <option value="en_livraison" <%= filtreStatut==='en_livraison' ? 'selected' : '' %>🛵 En livraison</option>
            <option value="servie" <%= filtreStatut==='servie' ? 'selected' : '' %>✅ Servies</option>
            <option value="annulee" <%= filtreStatut==='annulee' ? 'selected' : '' %>❌ Annulées</option>
          </select>
          <select name="type" class="form-control form-select" style="width:160px" onchange="this.form.submit()">
            <option value="tous" <%= filtreType==='tous' ? 'selected' : '' %>Tous types</option>
            <option value="sur_place" <%= filtreType==='sur_place' ? 'selected' : '' %>🪑 Sur place</option>
            <option value="a_emporter" <%= filtreType==='a_emporter' ? 'selected' : '' %>🛍️ À emporter</option>
            <option value="livraison" <%= filtreType==='livraison' ? 'selected' : '' %>🛵 Livraison</option>
          </select>
          <input type="date" name="date" class="form-control" style="width:170px" value="<%=filtreDate%>" onchange="this.form.submit()"/>
          <% if(filtreStatut!=='toutes'||filtreDate||filtreType!=='tous'){%><a href="/commandes" class="btn btn-secondary btn-sm"><i class="bi bi-x"></i> Réinitialiser</a><%}%>
        </form>
      </div>
    </div>

    <div id="commandesList">
      <% if(commandes.length===0){ %>
        <div class="empty-state"><div class="empty-state-icon"><i class="bi bi-bag-x"></i></div><h3>Aucune commande</h3><p>Les commandes apparaissent ici en temps réel dès qu'un client scanne votre QR code.</p></div>
      <% } else { %>
        <% commandes.forEach(cmd=>{ const map={en_attente:['warning','⏳ En attente'],en_preparation:['info','👨‍🍳 Préparation'],en_livraison:['purple','🛵 En route'],servie:['success','✅ Servie'],livree:['success','✅ Livrée'],annulee:['danger','❌ Annulée']}; const [stype,slabel]=map[cmd.statut]||['gray',cmd.statut]; const icon=cmd.type_livraison==='livraison'?'🛵':cmd.type_livraison==='a_emporter'?'🛍️':'🪑'; %>
          <div class="cmd-card" id="cmd-<%=cmd._id%>">
            <div class="cmd-card-header">
              <div style="display:flex;align-items:center;gap:12px">
                <span style="font-size:1.75rem"><%=icon%></span>
                <div>
                  <div style="display:flex;align-items:center;gap:8px">
                    <div class="cmd-num"><%=cmd.num_commande||''%></div>
                    <%
                      const payLabel = cmd.paiement==='mtn'?'📱 MTN':cmd.paiement==='orange'?'🟠 Orange':cmd.paiement==='cinetpay'?'🌍 MoMo':cmd.paiement==='stripe'?'💳 Carte':'💬 WA';
                      const payPaid  = cmd.paiement_statut==='success';
                      const payPend  = ['mtn','orange','cinetpay','stripe'].includes(cmd.paiement) && !payPaid;
                    %>
                    <span class="badge badge-gray" style="font-size:11px"><%=payLabel%></span>
                    <%if(payPaid){%><span class="badge badge-success" style="font-size:11px" title="Paiement confirmé">✅ Payé</span><%}%>
                    <%if(payPend){%><span class="badge" style="font-size:11px;background:#FEF3C7;color:#92400E" title="Paiement en attente">⏳ En attente</span><%}%>
                  </div>
                  <div class="cmd-client-name"><%=cmd.client_nom%></div>
                  <%if(cmd.client_telephone){%><div style="font-size:12px;color:var(--text-secondary)"><i class="bi bi-telephone"></i> <%=cmd.client_telephone%></div><%}%>
                  <%if(cmd.type_livraison==='livraison'&&cmd.client_adresse){%><div style="font-size:12px;color:var(--info)"><i class="bi bi-geo-alt"></i> <%=cmd.client_adresse%><%if(cmd.client_quartier){%>, <%=cmd.client_quartier%><%}%></div><%}%>
                  <%if(cmd.type_livraison==='sur_place'&&cmd.client_table){%><div style="font-size:12px;color:var(--text-secondary)"><i class="bi bi-table"></i> Table <%=cmd.client_table%></div><%}%>
                </div>
              </div>
              <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                <span class="badge badge-<%=stype%>" id="statut-<%=cmd._id%>"><%=slabel%></span>
                <span style="font-size:12px;color:var(--text-tertiary)"><i class="bi bi-clock"></i> <%=new Date(cmd.createdAt).toLocaleString('fr-FR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'})%></span>
              </div>
            </div>
            <div class="cmd-card-body">
              <div class="cmd-items-list">
                <%cmd.items.forEach(item=>{%>
                  <div class="cmd-item-row"><span class="cmd-qty"><%=item.quantite%>×</span><span class="cmd-item-name"><%=item.nom%></span><span class="cmd-item-price"><%=(item.prix*item.quantite).toLocaleString('fr-FR')%> F</span></div>
                <%});%>
              </div>
              <%if(cmd.note){%><div style="font-size:13px;color:var(--text-secondary);background:var(--warn-light);padding:8px 12px;border-radius:var(--r-xs);margin-top:8px;border-left:3px solid var(--warn)"><i class="bi bi-chat-text"></i> <%=cmd.note%></div><%}%>
              <%if(cmd.reduction>0){%><div style="font-size:13px;color:var(--accent-dark);margin-top:6px"><i class="bi bi-tag"></i> Promo <%=cmd.promo_code%> : -<%=cmd.reduction.toLocaleString('fr-FR')%> FCFA</div><%}%>
            </div>
            <div class="cmd-card-footer">
              <div class="cmd-total"><%=cmd.total.toLocaleString('fr-FR')%> FCFA</div>
              <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center" id="actions-<%=cmd._id%>">
                <%if(cmd.statut==='en_attente'){%>
                  <button class="btn btn-sm btn-primary" onclick="changerStatut('<%=cmd._id%>','en_preparation',this)"><i class="bi bi-fire"></i> Préparer</button>
                  <button class="btn btn-sm btn-secondary" onclick="changerStatut('<%=cmd._id%>','annulee',this)"><i class="bi bi-x"></i> Annuler</button>
                <%}else if(cmd.statut==='en_preparation'&&cmd.type_livraison==='livraison'){%>
                  <select id="livreur-sel-<%=cmd._id%>" class="form-control form-select" style="width:160px;height:34px;padding:5px 10px;font-size:13px">
                    <option value="">Choisir livreur...</option>
                    <%livreurs.forEach(l=>{%><option value="<%=l._id%>">🛵 <%=l.nom%></option><%});%>
                  </select>
                  <button class="btn btn-sm btn-primary" onclick="assignerLivreur('<%=cmd._id%>')"><i class="bi bi-scooter"></i> Livrer</button>
                <%}else if(cmd.statut==='en_preparation'){%>
                  <button class="btn btn-sm btn-success" onclick="changerStatut('<%=cmd._id%>','servie',this)"><i class="bi bi-check-circle"></i> Servir</button>
                <%}else if(cmd.statut==='en_livraison'){%>
                  <button class="btn btn-sm btn-success" onclick="changerStatut('<%=cmd._id%>','livree',this)"><i class="bi bi-check-all"></i> Livrée</button>
                <%}%>
                <a href="/commandes/<%=cmd._id%>/recu" target="_blank" class="btn btn-sm btn-secondary btn-icon" title="Reçu PDF"><i class="bi bi-file-earmark-pdf"></i></a>
                <a href="/commandes/suivi/<%=cmd.num_commande%>" target="_blank" class="btn btn-sm btn-secondary btn-icon" title="Lien de suivi"><i class="bi bi-link-45deg"></i></a>
                <form method="POST" action="/commandes/<%=cmd._id%>/supprimer" style="display:inline" onsubmit="return confirm('Supprimer ?')"><button type="submit" class="btn btn-sm btn-secondary btn-icon"><i class="bi bi-trash3"></i></button></form>
              </div>
            </div>
          </div>
        <%});%>
      <%}%>
    </div>
  </div>
</div>
    <!-- Carte des livraisons -->
    <div id="mapSection" class="card" style="margin-top:1.5rem">
      <div class="card-header-bar">
        <div>
          <div class="card-title"><i class="bi bi-map"></i> Carte des livraisons</div>
          <div class="card-subtitle">Positions des commandes de livraison en cours</div>
        </div>
        <div style="display:flex;gap:8px;align-items:center">
          <span id="mapCmdBadge" class="badge badge-gray">Chargement...</span>
          <button id="refreshMap" onclick="initCommandesMapPage()" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-clockwise"></i> Actualiser</button>
        </div>
      </div>
      <div style="padding:0">
        <div id="commandesMap" class="leaflet-map-wrap" style="height:420px;border-radius:0 0 16px 16px"></div>
      </div>
      <div class="card-body" style="padding:.75rem 1.25rem">
        <div class="map-legend">
          <div class="legend-item"><div class="legend-dot" style="background:#F59E0B"></div> En attente</div>
          <div class="legend-item"><div class="legend-dot" style="background:#3B82F6"></div> En préparation</div>
          <div class="legend-item"><div class="legend-dot" style="background:#8B5CF6"></div> En livraison</div>
          <div class="legend-item"><div class="legend-dot" style="background:#10B981"></div> Livrée</div>
          <div class="legend-item"><div class="legend-dot" style="background:#1B4332"></div> Votre restaurant</div>
        </div>
      </div>
    </div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/commandes.js"></script>
<script src="/js/app.js"></script>
<script>const restaurantId='<%=restaurantId%>';</script>
</body></html>

<!-- Leaflet init for commandes -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/map-dashboard.js"></script>
<script>
async function initCommandesMapPage() {
  try {
    const [commandes, restaurant] = await Promise.all([
      fetch('/maps/commandes').then(r => r.json()),
      fetch('/maps/restaurant').then(r => r.json()),
    ]);
    const badge = document.getElementById('mapCmdBadge');
    if (badge) {
      badge.className = commandes.length > 0 ? 'badge badge-success' : 'badge badge-gray';
      badge.textContent = commandes.length > 0 ? commandes.length + ' livraison(s)' : 'Aucune livraison';
    }
    initCommandesMap(commandes, restaurant);
  } catch(e) {
    console.error('Erreur carte commandes:', e);
  }
}
initCommandesMapPage();
</script>
