<%- include('../partials/head', {title:'Mon profil'}) %>
<%- include('../partials/sidebar', {activePage:'profil'}) %>
<div class="main-content">
  <div class="topbar"><div class="topbar-left"><button class="sidebar-toggle" id="sidebarToggle"><i class="bi bi-list"></i></button><div class="topbar-title">Mon profil</div></div></div>
  <div class="page-body">
    <% if(error&&error.length>0){%><div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i><%=error%></div><%}%>
    <% if(success&&success.length>0){%><div class="alert alert-success"><i class="bi bi-check-circle"></i><%=success%></div><%}%>
    <div class="card">
      <div class="card-header-bar"><div class="card-title">Informations du restaurant</div></div>
      <div class="card-body">
        <form method="POST" action="/dashboard/profil" enctype="multipart/form-data">
          <div style="display:grid;grid-template-columns:260px 1fr;gap:2rem">
            <div>
              <label class="form-label">Logo</label>
              <div class="photo-upload-zone" id="photoZone">
                <%if(restaurant.logo){%><img src="<%=restaurant.logo%>" class="preview" style="width:100%;height:100%;object-fit:cover"/><%}else{%>
                <div class="upload-placeholder" style="display:flex;flex-direction:column;align-items:center;gap:8px;color:var(--text-tertiary)"><i class="bi bi-shop" style="font-size:2rem"></i><span style="font-size:13px">Logo du restaurant</span></div><%}%>
                <input type="file" name="logo" accept="image/*" style="display:none"/>
              </div>
            </div>
            <div>
              <div style="margin-bottom:1rem"><label class="form-label">Nom *</label><input type="text" name="nom" class="form-control" value="<%=restaurant.nom%>" required/></div>
              <div style="margin-bottom:1rem"><label class="form-label">Téléphone *</label><input type="tel" name="telephone" class="form-control" value="<%=restaurant.telephone%>" required/></div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
                <div><label class="form-label">Adresse</label><input type="text" name="adresse" class="form-control" value="<%=restaurant.adresse||''%>"/></div>
                <div><label class="form-label">Ville</label><select name="ville" class="form-control form-select"><%['Douala','Yaoundé','Bafoussam','Bamenda','Garoua','Autre'].forEach(v=>{%><option value="<%=v%>" <%=restaurant.ville===v?'selected':''%>><%=v%></option><%});%></select></div>
              </div>
              <div><label class="form-label">Description</label><textarea name="description" class="form-control" rows="3"><%=restaurant.description||''%></textarea></div>
            </div>
          </div>
          <div style="display:flex;justify-content:flex-end;gap:12px;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border)">
            <a href="/dashboard" class="btn btn-secondary">Annuler</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy"></i> Enregistrer</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body></html>
