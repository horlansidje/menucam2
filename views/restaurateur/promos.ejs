<%- include('../partials/head', {title:'Promotions'}) %>
<%- include('../partials/sidebar', {activePage:'promos'}) %>
<div class="main-content">
  <div class="topbar"><div class="topbar-left"><button class="sidebar-toggle" id="sidebarToggle"><i class="bi bi-list"></i></button><div class="topbar-title">Codes promo</div></div></div>
  <div class="page-body">
    <% if(error&&error.length>0){%><div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i><%=error%></div><%}%>
    <% if(success&&success.length>0){%><div class="alert alert-success"><i class="bi bi-check-circle"></i><%=success%></div><%}%>
    <div style="display:grid;grid-template-columns:1fr 360px;gap:1.5rem;align-items:start">
      <div>
        <% if(promos.length===0){ %>
          <div class="empty-state"><div class="empty-state-icon"><i class="bi bi-tag"></i></div><h3>Aucune promotion</h3><p>Créez des codes promo pour fidéliser vos clients.</p></div>
        <% } else { %>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem">
            <%promos.forEach(p=>{const expire=p.date_fin&&new Date()>new Date(p.date_fin);%>
              <div class="card">
                <div style="padding:1rem 1.25rem;background:<%=!p.actif||expire?'var(--gray-100)':'linear-gradient(135deg,#064E3B,#065F46)'%>;border-radius:var(--r-md) var(--r-md) 0 0;display:flex;justify-content:space-between;align-items:center">
                  <div style="font-family:'Bricolage Grotesque',sans-serif;font-size:1.3rem;font-weight:800;color:<%=!p.actif||expire?'var(--text-secondary)':'#fff'%>;letter-spacing:.05em"><%=p.code%></div>
                  <span class="badge <%=!p.actif||expire?'badge-gray':'badge-success'%>"><%=!p.actif?'Inactif':expire?'Expiré':'Actif'%></span>
                </div>
                <div class="card-body">
                  <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px"><span style="color:var(--text-secondary)">Réduction</span><strong style="color:var(--brand)"><%=p.type==='pourcentage'?p.valeur+'%':p.valeur.toLocaleString('fr-FR')+' FCFA'%></strong></div>
                  <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px"><span style="color:var(--text-secondary)">Utilisations</span><span><%=p.utilisations%>/<%=p.max_utilisations%></span></div>
                  <%if(p.min_commande>0){%><div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px"><span style="color:var(--text-secondary)">Minimum commande</span><span><%=p.min_commande.toLocaleString('fr-FR')%> FCFA</span></div><%}%>
                  <%if(p.date_fin){%><div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px"><span style="color:var(--text-secondary)">Expire le</span><span><%=new Date(p.date_fin).toLocaleDateString('fr-FR')%></span></div><%}%>
                  <%if(p.description){%><p style="font-size:12px;color:var(--text-secondary);margin-bottom:12px"><%=p.description%></p><%}%>
                  <div style="display:flex;gap:8px">
                    <button onclick="togglePromo('<%=p._id%>',this)" class="btn btn-sm btn-secondary" style="flex:1"><%=p.actif?'⏸️ Désactiver':'▶️ Activer'%></button>
                    <form method="POST" action="/promos/<%=p._id%>/supprimer" onsubmit="return confirm('Supprimer ?')"><button class="btn btn-sm btn-secondary btn-icon"><i class="bi bi-trash3"></i></button></form>
                  </div>
                </div>
              </div>
            <%});%>
          </div>
        <%}%>
      </div>
      <div class="card">
        <div class="card-header-bar"><div class="card-title">➕ Nouvelle promotion</div></div>
        <div class="card-body">
          <form method="POST" action="/promos/nouvelle">
            <div style="margin-bottom:.9rem"><label class="form-label">Code promo *</label><input type="text" name="code" class="form-control" placeholder="Ex: BIENVENUE20" required style="text-transform:uppercase"/></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:.9rem">
              <div><label class="form-label">Type *</label><select name="type" class="form-control form-select"><option value="pourcentage">Pourcentage (%)</option><option value="fixe">Montant fixe (F)</option></select></div>
              <div><label class="form-label">Valeur *</label><input type="number" name="valeur" class="form-control" placeholder="20" min="1" required/></div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:.9rem">
              <div><label class="form-label">Commande min.</label><input type="number" name="min_commande" class="form-control" placeholder="0" min="0"/></div>
              <div><label class="form-label">Max utilisations</label><input type="number" name="max_utilisations" class="form-control" placeholder="999" min="1"/></div>
            </div>
            <div style="margin-bottom:.9rem"><label class="form-label">Date d'expiration</label><input type="date" name="date_fin" class="form-control"/></div>
            <div style="margin-bottom:1.25rem"><label class="form-label">Description</label><input type="text" name="description" class="form-control" placeholder="Ex: Offre de bienvenue"/></div>
            <button type="submit" class="btn btn-primary" style="width:100%"><i class="bi bi-tag"></i> Créer le code promo</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
async function togglePromo(id, btn) {
  const r = await fetch(`/promos/${id}/toggle`, {method:'POST'}).then(r=>r.json());
  btn.textContent = r.actif ? '⏸️ Désactiver' : '▶️ Activer';
}
</script>
<script src="/js/app.js"></script>
</body></html>
