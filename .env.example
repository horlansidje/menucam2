# ════════════════════════════════════════════════════════════
#  MenuCam V3 — Variables d'environnement
#  ► Copiez ce fichier en .env pour le développement local
#  ► Sur Railway : ajoutez ces variables dans le dashboard
# ════════════════════════════════════════════════════════════

# ── Serveur ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# URL publique de votre app (récupérez-la après déploiement Railway)
# Exemple : https://menucam-production.up.railway.app
APP_URL=https://menucam-production.up.railway.app

# ── Sécurité ────────────────────────────────────────────────
# Générez une clé aléatoire longue (min 32 caractères)
SESSION_SECRET=changez_ceci_avec_une_cle_tres_longue_et_aleatoire_32chars

# ── Base de données ─────────────────────────────────────────
# NeDB local (développement uniquement — données éphémères sur Railway)
# DB_PATH=./data

# ⚠️  IMPORTANT Railway : les données NeDB sont perdues à chaque redéploiement
# Pour persister vos données, utilisez MongoDB Atlas (gratuit 512MB)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/menucam

# ── Uploads (images plats) ──────────────────────────────────
# Sur Railway : les fichiers locaux sont éphémères
# Utilisez Cloudinary pour stocker les images de façon permanente
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Délai annulation commande (minutes) ─────────────────────
DELAI_ANNULATION_MIN=5

# ── Chatbot IA (Assistant client MenuCam) ───────────────────
# Créez votre clé GRATUITE sur : https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Mode Simulation Paiement ────────────────────────────────
# Activez pour démonstration sans clés API réelles (jury, tests)
# Auto-activé si aucune clé MTN/Orange/CinetPay n'est définie
PAYMENT_SIMULATION=true

# ── CinetPay (MTN, Orange, Wave, Moov — Afrique) ────────────
# Compte sur : https://cinetpay.com
CINETPAY_APIKEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=

# ── MTN Mobile Money (API directe Cameroun) ─────────────────
# Compte développeur : https://momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=
MTN_API_USER=
MTN_API_KEY=
MTN_ENV=sandbox

# ── Orange Money ─────────────────────────────────────────────
# Compte : https://developer.orange.com
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_MERCHANT_KEY=

# ── Stripe (Visa/Mastercard international) ──────────────────
# Compte : https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
